#!/bin/bash
# Open a file in nvim inside a tmux popup modal.
# Used as $EDITOR so tools like Claude Code open files in a floating tmux window.
# Plan files are routed to the browser-based plan reviewer instead.
FILE="$1"
DOTFILES="$(dirname "$(dirname "$(realpath "$0")")")"
PLAN_REVIEWER="${DOTFILES}/tools/plan-reviewer/dist/cli.js"

if [[ "$FILE" == *"/.claude/plans/"* ]]; then
  exec "$PLAN_REVIEWER" "$FILE"
fi

# Empty input from Claude Code's external editor → open plan if one was recently active
if [[ ! -s "$FILE" ]]; then
  LATEST_PLAN=$(ls -t "${HOME}/.claude/plans/"*.md 2>/dev/null | head -1)
  if [[ -n "$LATEST_PLAN" ]]; then
    PLAN_AGE=$(($(date +%s) - $(stat -f %m "$LATEST_PLAN")))
    if [[ $PLAN_AGE -lt 600 ]]; then
      exec "$PLAN_REVIEWER" "$LATEST_PLAN"
    fi
  fi
fi

if [ -n "$TMUX" ]; then
  tmux popup -E -w 100% -h 100% "nvim $(printf '%q' "$FILE")"
  tmux refresh-client
else
  exec nvim "$FILE"
fi
