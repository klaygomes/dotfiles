# Taskwarrior configuration

data.location=~/.local/share/task

# Appearance
color=on
defaultwidth=120

# Theme — One Double Dark (matches ghostty + tmux)
color.header=bold color12
color.label=bold color12
color.alternate=on color234
color.active=bold color10
color.due=color3
color.due.today=bold color11
color.overdue=bold color9
color.blocked=color8
color.blocking=bold color7
color.priority.H=bold color9
color.priority.M=color11
color.priority.L=color8
color.project.none=color8
color.completed=color8
color.deleted=color8
color.tag.next=bold color13

# Journal / history
journal.info=yes

# Editor
editor=nvim

# Behaviour
default.command=next
search.case.sensitive=no
bulk=5
nag=
recurrence.confirmation=no
confirmation=no

# Due / scheduled defaults
due=7

# Urgency coefficients
urgency.due.coefficient=12.0
urgency.blocking.coefficient=8.0
urgency.age.coefficient=2.0
urgency.annotations.coefficient=1.0
urgency.user.tag.next.coefficient=15.0

# Reports
report.next.columns=id,start.age,entry.age,depends,priority,project,tags,recur,scheduled.countdown,due.relative,until.remaining,description,urgency
report.next.labels=ID,Active,Age,Deps,P,Project,Tags,Recur,S,Due,Until,Description,Urg
report.next.sort=urgency-
report.next.filter=status:pending limit:30

report.list.columns=id,priority,project,tags,due.relative,description,urgency
report.list.labels=ID,P,Project,Tags,Due,Description,Urg
report.list.sort=urgency-
report.list.filter=status:pending
news.version=3.4.2
